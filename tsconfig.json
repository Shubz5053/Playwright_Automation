{
  "compilerOptions": {
    "target": "ESNext",
    "module": "commonjs",
    "lib": [
      "ESNext"
    ],
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowJs": true,
    "outDir": "dist",
    "strict": true,
    "types": [
      "node",
      "@playwright/test"
    ],
    "ignoreDeprecations": "6.0",
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*.ts",
    "playwright.config.ts"
  ]
}